# Upstash Redis (ได้จาก https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Slip verification — ใส่อย่างน้อย 1 key (ระบบจะลอง Tabscanner ก่อน แล้ว fallback ไป EasySlip)
TABSCANNER_API_KEY=      # https://tabscanner.com/
EASYSLIP_API_KEY=        # https://easyslip.com/

# API secret — ป้องกัน POST /api/store จากภายนอก (ต้องตั้งค่าทั้ง 2 ให้เหมือนกัน)
STORE_API_SECRET=your-random-secret-here
NEXT_PUBLIC_STORE_API_SECRET=your-random-secret-here
